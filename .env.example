# Copy to .env and fill. Never commit .env.

# ---- Twilio ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15551234567

# The one user of this system. Inbound messages from any other number are dropped.
USER_PHONE=+15105086694

# ---- User / timezone ----
USER_TZ=America/Los_Angeles

# ---- LLM providers (any subset; LiteLLM routes based on fallback chain) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=

# Primary model per call type (LiteLLM model strings).
#
# Chain design (artificialanalysis.ai/models + Intelligence-vs-Price chart, April 2026):
#
#   Intelligence Index (higher = smarter):
#     GPT-5.4 xhigh          57
#     Gemini 3.1 Pro         57   ← "most attractive quadrant" — best intel/$ at the frontier
#     GPT-5.4 mini (xhigh)   54
#     Claude Sonnet 4.6 max  52
#     Claude Opus 4.6 max    53   ← worst intel/$ on the chart (~$10+/M)
#     MiniMax-M2.7           50   ← "most attractive quadrant" — ~$0.60/M
#     Gemini 3 Flash         45
#     Claude Haiku 4.5       37   ← pricier than MiniMax-M2.7 AND lower Intelligence
#
# Fallback ordering rules:
#   1. Primary = Anthropic — prompts are tuned there, Instructor structured-output is reliable, latency is good.
#   2. Favor intelligence-per-dollar in fallbacks (per the Intelligence-vs-Price chart).
#   3. First fallback is a different provider family (resilience against an Anthropic-wide outage).
#   4. Opus pushed to the END of the quality chain: by the time we've failed Anthropic once, retrying the
#      same infra at 15-20x the cost of alternatives is the wrong trade. Use it only as absolute last resort.
#   5. MiniMax promoted from "last" to early-fallback: it's in the attractive quadrant and provides cross-provider resilience.

# Model IDs below were validated against real APIs by scripts/probe_llm.py:
#   Gemini: the "3" series models are preview-tagged; LiteLLM passes names through to Google's API.
#   MiniMax: LiteLLM's registry caps at M2.5 (not M2.7); capital "MiniMax-M2.5" is required.
#     -lightning variant = faster/cheaper, suitable for fast tier.

# ---- Fast tier: classifier, warm-ack, timer parser. Low latency (<2s soft / <5s hard). ----
# MiniMax-M2.5 promoted to primary: cheapest on the chart ($0.30/M in, $1.20/M out), struct latency ~1.1s,
# Intelligence Index ~48 (higher than Haiku's ~37). Anthropic Haiku now the Anthropic-ecosystem fallback.
LLM_FAST_MODEL=minimax/MiniMax-M2.5
LLM_FAST_FALLBACKS=anthropic/claude-haiku-4-5,gemini/gemini-3-flash-preview,openai/gpt-5.4-mini

# ---- Quality tier: morning pushback, evening follow-up, Friday summary. ----
# MiniMax-M2.5 primary for cost-first quality. Still runs on cron/BackgroundTasks, so latency isn't the constraint.
# Watchpoint: our prompts were tuned on Claude voice — if MiniMax's output style is off, swap primary back to Sonnet.
LLM_QUALITY_MODEL=minimax/MiniMax-M2.5
LLM_QUALITY_FALLBACKS=anthropic/claude-sonnet-4-5,openai/gpt-5.4,gemini/gemini-3.1-pro-preview,anthropic/claude-opus-4-6

# ---- Google Sheets ----
GOOGLE_SHEETS_ID=1Z0tr3rYgpLBYz5jYKhHMV2Hk-ZWJNDSVNy3j2mxvTT0
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/Users/shadowclone/Desktop/Code/overwatcher/resources/overwatcher-289703-c1fdbd175e78.json

# ---- Storage ----
# SQLite file path. Use an absolute path on the home server: /var/lib/overwatcher/state.db
DATABASE_URL=sqlite:///./state.db

# ---- Web ----
# Public base URL Twilio will hit (via Cloudflare Tunnel). Used to validate webhook signatures.
PUBLIC_WEBHOOK_BASE_URL=https://overwatcher.example.dev

# Bind address for local uvicorn. Cloudflare tunnel should point here.
HOST=127.0.0.1
PORT=8000

# ---- Misc ----
LOG_LEVEL=INFO
